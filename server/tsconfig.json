{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "server.ts",
    "config/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "routes/**/*",
    "types/**/*",
    "prisma/seed.ts"
  ],
  "exclude": ["node_modules", "dist", "prisma/data"],
  "ts-node": {
    "files": true
  }
}
